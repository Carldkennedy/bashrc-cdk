# Common aliases
bashrc() {
  local host="${hostname:-unknown}"
  printf '%s\n%s\n' \
    "https://github.com/Carldkennedy/bashrc-cdk/edit/main/bashrc_${host}" \
    "https://github.com/Carldkennedy/bashrc-cdk/edit/main/bashrc_common"
}

ale() {
  local host="${hostname:-unknown}"
  printf '%s\n%s\n' \
    "https://github.com/Carldkennedy/bashrc-cdk/edit/main/bash_aliases_${host}" \
    "https://github.com/Carldkennedy/bashrc-cdk/edit/main/bash_aliases_common"
}

bl() {
  local host="${hostname:-unknown}"
  printf '\n%s\n' "$host"
  if [[ -f "$HOME/bashrc-cdk/bashrc_${host}" ]]; then
    grep -o '.*()' "$HOME/bashrc-cdk/bashrc_${host}"
  fi
  printf '\nCOMMON\n'
  grep -o '.*()' "$HOME/bashrc-cdk/bashrc_common"
}

al() {
  local host="${hostname:-unknown}"
  more "$HOME/bashrc-cdk/bash_aliases_${host}" "$HOME/bashrc-cdk/bash_aliases_common"
}

alg() {
  local host="${hostname:-unknown}"
  cat "$HOME/bashrc-cdk/bash_aliases_${host}" "$HOME/bashrc-cdk/bash_aliases_common" | grep -i "$@"
}

sc() {
  local host="${hostname:-unknown}"
  more "$HOME/bashrc-cdk/sc_${host}" "$HOME/bashrc-cdk/sc_common"
}

sce() {
  local host="${hostname:-unknown}"
  printf '%s\n%s\n' \
    "https://github.com/Carldkennedy/bashrc-cdk/edit/main/sc_${host}" \
    "https://github.com/Carldkennedy/bashrc-cdk/edit/main/sc_common"
}

scg() {
  local host="${hostname:-unknown}"
  cat "$HOME/bashrc-cdk/sc_${host}" "$HOME/bashrc-cdk/sc_common" | grep -i "$@"
}

alias less="less -R"
# Watching changes in ps aux output
alias pswatch="watch -n 0.2 'ps aux | sort > /tmp/ps1 && sleep 0.2 && ps aux | sort > /tmp/ps2 && comm -13 /tmp/ps1 /tmp/ps2'"
pslog() {
  while true; do
    printf '\n%s\n' "$(date)"
    comm -13 <(ps aux | sort) <(sleep 0.1 && ps aux | sort)
    sleep 0.1
  done >> ps.log
}
