# fzf fuzzy search
alias fzp='fzf --preview "cat {}"'
alias fzh='history | fzf'
fcd() {
  local dir
  dir=$(find . -type d -not -path '*/.git/*' 2>/dev/null | fzf) && cd "$dir"
}
fkill() {
  local pids
  pids=$(ps -ef | sed 1d | fzf -m | awk '{print $2}')
  if [[ -n "$pids" ]]; then
    kill $pids
  fi
}

pathls() {
  echo "$PATH" | tr ':' '\n'
}
pathadd() {
  local dir="$1"
  [[ -n "$dir" ]] || return 1
  case ":$PATH:" in
    *":$dir:"*) ;;
    *) PATH="$PATH:$dir" ;;
  esac
}
pathprepend() {
  local dir="$1"
  [[ -n "$dir" ]] || return 1
  case ":$PATH:" in
    *":$dir:"*) ;;
    *) PATH="$dir:$PATH" ;;
  esac
}
pathrm() {
  local dir="$1" newpath
  [[ -n "$dir" ]] || return 1
  IFS=':' read -r -a parts <<< "$PATH"
  for part in "${parts[@]}"; do
    [[ "$part" == "$dir" ]] && continue
    newpath="${newpath:+$newpath:}$part"
  done
  PATH="$newpath"
}
